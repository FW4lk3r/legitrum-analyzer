# Legitrum Analyzer — Environment Variables
# Copy this file to .env.secrets and fill in the values.
# NEVER commit .env.secrets to version control.

# Required: API token for Legitrum platform
# Generate at: legitrum.com/settings/tokens
# Rotate quarterly. Distribute new tokens via Legitrum dashboard only — never via email/chat/Slack.
# After rotation, revoke the old token immediately.
LEGITRUM_TOKEN=

# Required: Assessment ID to analyze
ASSESSMENT_ID=

# Optional: Legitrum server URL (default: https://legitrum.com)
LEGITRUM_SERVER=https://legitrum.com

# Optional: Log level (default: info)
LOG_LEVEL=info

# Optional: Path to project to analyze (default: current directory)
PROJECT_PATH=/path/to/your/project

# Optional: Log destination (default: stderr)
# Use a file path to persist logs: /var/log/legitrum/analyzer.log
# File permissions are set to 0640 automatically.
# LOG_DESTINATION=stderr
LOG_DESTINATION=stderr

# Optional: Application environment (default: development)
# Set to 'production' to suppress stack traces and enforce info log level
APP_ENV=development
