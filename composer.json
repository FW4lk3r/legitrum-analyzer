{
    "name": "legitrum/analyzer",
    "description": "Legitrum Compliance Analyzer — runs on client infrastructure",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "~8.2.0",
        "guzzlehttp/guzzle": "7.10.0"
    },
    "autoload": {
        "psr-4": {
            "Legitrum\\Analyzer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Legitrum\\Analyzer\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "cyclonedx/cyclonedx-php-composer": "5.3.0",
        "phpstan/phpstan": "2.1.46"
    },
    "scripts": {
        "audit": "composer audit --format=plain",
        "audit:enforce": "composer audit && echo 'Audit passed — no known vulnerabilities'",
        "audit:json": "composer audit --format=json",
        "sbom": "composer CycloneDX:make-sbom --output-file=sbom.cdx.json --spec-version=1.5",
        "test": "phpunit --testdox",
        "analyse": "phpstan analyse --error-format=table"
    },
    "config": {
        "allow-plugins": {
            "cyclonedx/cyclonedx-php-composer": true
        }
    },
    "minimum-stability": "stable"
}
